# ════════════════════════════════════════════════════════════════════════
#  .env mẫu cho HOSTING cPanel (KHÔNG Docker, KHÔNG Redis, KHÔNG Node nền)
#  → Copy thành .env trên server rồi điền giá trị thật.
#  Lưu ý: Laravel 11 đọc CACHE_STORE (không phải CACHE_DRIVER).
# ════════════════════════════════════════════════════════════════════════

APP_NAME="Maha Spa"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_URL=https://mahaspa.vn

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_AVAILABLE_LOCALES=vi,en,ja,ko,zh
AUTH_REGISTRATION_ENABLED=false

LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Database (lấy từ cPanel → MySQL Databases). Tên thường có prefix user_ ──
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cpaneluser_mahaspa
DB_USERNAME=cpaneluser_maha
DB_PASSWORD=

# ── KHÔNG có Redis trên shared hosting → dùng file / database ──
BROADCAST_CONNECTION=log
CACHE_STORE=database
FILESYSTEM_DISK=public
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Queue ──
# database = job chạy qua cron worker (xem DEPLOY-CPANEL.md). Khuyên dùng.
# sync     = chạy ngay trong request (không cần cron), nhưng gửi mail làm
#            chậm response ~1-3s. Đổi sang sync nếu không set được cron worker.
QUEUE_CONNECTION=database

# ── Mail: dùng SMTP của hosting hoặc Mailgun/SendGrid ──
MAIL_MAILER=smtp
MAIL_HOST=mail.mahaspa.vn
MAIL_PORT=465
MAIL_USERNAME=no-reply@mahaspa.vn
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="no-reply@mahaspa.vn"
MAIL_FROM_NAME="${APP_NAME}"

# ── SMS ──
SMS_PROVIDER=twilio
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ── Payment — VNPay ──
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL="${APP_URL}/payment/vnpay/return"

# ── Payment — MoMo ──
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create

# ── Analytics ──
GTM_ID=GTM-TTGB95P9
GA4_ID=

# ── Filament ──
FILAMENT_FILESYSTEM_DISK=public

# ── Auto-translate: null | google | deepl | openai | gemini ──
TRANSLATE_PROVIDER=null
GOOGLE_TRANSLATE_KEY=
DEEPL_KEY=
DEEPL_ENDPOINT=https://api-free.deepl.com/v2/translate
OPENAI_KEY=
OPENAI_TRANSLATE_MODEL=gpt-4o-mini
GEMINI_KEY=
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent
