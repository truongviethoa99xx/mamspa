APP_NAME="Maha Spa"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_URL=http://localhost
APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_AVAILABLE_LOCALES=vi,en,ja,ko,zh
AUTH_REGISTRATION_ENABLED=false

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mahaspa
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_CONNECTION=reverb
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=1440

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Laravel Reverb — WebSocket server cho thông báo realtime admin (booking/liên hệ mới)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@mahaspa.vn"
MAIL_FROM_NAME="${APP_NAME}"

# SMS Provider (Twilio hoặc Viettel)
SMS_PROVIDER=twilio
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# Payment — VNPay
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL="${APP_URL}/payment/vnpay/return"

# Payment — MoMo
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create

# Google Tag Manager / Analytics
GTM_ID=GTM-W6NJ4P3S
GA4_ID=G-Z290RGPXMG

# Google OAuth Login (Socialite) — lấy từ Google Cloud Console > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://mamspa.vn/api/auth/callback/google

# Google Business Profile — admin kết nối để đồng bộ toàn bộ review thật (không giới hạn 5 như Places API).
# Yêu cầu: GBP đã xác minh, gửi đơn xin quyền tại https://developers.google.com/my-business/content/prereqs
# và thêm URI này vào "Authorized redirect URIs" (cùng OAuth Client ID phía trên).
GOOGLE_BUSINESS_REDIRECT_URI=https://mamspa.vn/admin/integrations/google-business/callback

# Google Places API — hiển thị review Google Maps thật của từng chi nhánh.
# Bật "Places API" trên Google Cloud Console (cần bật billing, có gói miễn phí
# hàng tháng), tạo API key ở mục Credentials.
GOOGLE_PLACES_API_KEY=

# Filament
FILAMENT_FILESYSTEM_DISK=public

# Auto-translate provider: null | google | deepl | openai | gemini
TRANSLATE_PROVIDER=null
GOOGLE_TRANSLATE_KEY=
DEEPL_KEY=
DEEPL_ENDPOINT=https://api-free.deepl.com/v2/translate
OPENAI_KEY=
OPENAI_TRANSLATE_MODEL=gpt-4o-mini
GEMINI_KEY=
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent
