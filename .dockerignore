# VCS
.git
.gitignore
.github

# Dependencies (reinstalled inside the image)
node_modules
vendor

# Build artifacts (regenerated in the assets stage)
public/build
public/hot
bootstrap/ssr

# Local environment & secrets — never bake into the image
.env
.env.*
!.env.example
.npmrc

# Runtime / cache
storage/logs/*
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*.php

# Dev tooling & docs
tests
*.md
.editorconfig
.prettierrc*
.eslintrc*
phpunit.xml
